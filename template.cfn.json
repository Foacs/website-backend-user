{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Parameters": {
    "Env": {
      "Type": "String",
      "Description": "The target environment name"
    },
    "ApiId": {
      "Type": "String"
    }
  },
  "Resources": {
    "GetFunctionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        }
      }
    },
    "GetFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "Architectures": ["arm64"],
        "FunctionName": "user-get",
        "Handler": "index.handler",
        "PackageType": "Zip",
        "Code": {
          "S3Bucket": "foacs-website-deploys",
          "S3Key": "development/user/artifacts/get.zip"
        },
        "Role": {"Fn::GetAtt": ["GetFunctionRole", "Arn"]},
        "Runtime": "nodejs16.x"
      }
    },
    "GetRoute": {
      "Type": "AWS::ApiGatewayV2::Route",
      "Properties": {
        "ApiId": {
          "Ref": "ApiId"
        },
        "RouteKey": "GET /users"
      }
    }
  }
}
